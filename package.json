{
  "name": "mirror",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "module": "main.mjs",
  "scripts": {
    "build": "bun build ./server/index.ts --outdir ./build --target bun --external googleapis --format esm",
    "clean": "rm -rf dist",
    "dev": "bun --watch ./server/index.ts",
    "electron": "dotenv wait-on http://localhost:$API_PORT/ && electron main.mjs",
    "generate-message": "bun ./server/modules/message/generate-message.ts",
    "google:albumIds": "bun ./server/scripts/fetch-album-ids.ts",
    "google:authorize": "bun ./server/scripts/authorize.ts",
    "lint": "tsc --noEmit && eslint \"src/**/*.ts*\"",
    "spotify:types": "./node_modules/.bin/oazapfts --optimistic ./fixed-spotify-open-api.yml ./server/modules/spotify/spotify.api.ts",
    "start": "bun ./dist/server/index.js",
    "test:calendar": "bun ./server/scripts/test-google-calendar.ts",
    "test:photos": "bun ./server/scripts/test-google-photos.ts",
    "test:spotify": "bun ./server/scripts/test-spotify.ts",
    "test:weather": "bun ./server/scripts/test-weather.ts",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.0",
    "cron": "^3.1.6",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "electron": "^28.1.0",
    "googleapis": "^129.0.0",
    "pino": "^8.17.1",
    "preact": "^10.19.3",
    "preact-render-to-string": "^6.3.1",
    "wait-on": "^7.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@total-typescript/ts-reset": "^0.5.1",
    "@types/bun": "^1.0.0",
    "@types/eslint": "^8.56.0",
    "@types/node": "^20.10.5",
    "@types/prettier": "^2.7.3",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n": "^16.5.0",
    "eslint-plugin-perfectionist": "^2.5.0",
    "oazapfts": "^4.12.0",
    "pino-pretty": "^10.3.0",
    "prettier": "^2.8.8",
    "prettier-plugin-packagejson": "^2.4.7",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
